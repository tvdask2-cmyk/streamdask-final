{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreamDask Mix Live",
  "version": "0.1.0",
  "identifier": "com.streamdask.mixlive",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StreamDask Mix Live",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "Plateforme de streaming et de mix live audio/video",
    "longDescription": "Application desktop native StreamDask Mix Live pour diffuser, mixer et rejouer des lives audio/video."
  }
}